# Server
PORT=3000

# Mail settings
# Address that should receive contact form submissions
MAIL_TO=info@example.com

# SMTP transport configuration
# For common providers (e.g., Gmail), set:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_username
# SMTP_PASS=your_password_or_app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
